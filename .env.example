# Copy to .env and fill in. .env is gitignored — never commit keys.

# Required for the `anthropic` endpoint (Phase 2+; Phase 1 stubs make zero LLM calls).
# The driver loads this from .env and injects it per spawned session — it is
# never exported into the driver's own process environment.
ANTHROPIC_API_KEY=sk-ant-...

# Only needed when an endpoint in config.yaml uses auth_env: OLLAMA_AUTH
# (local Ollama backend, Phase 4). The value is a protocol placeholder that
# Ollama ignores.
OLLAMA_AUTH=ollama
