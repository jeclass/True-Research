# Run state — never commit research runs
runs/

# Eval outputs (scores + per-run reports stay local, like runs/)
evals/results/

# Reranker model cache (FlashRank ONNX, downloaded on first use)
.flashrank_cache/

# Local working notes from skill-driven planning (not deliverable docs)
docs/superpowers/

# Secrets
.env

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# OS / editor noise
.DS_Store
*.swp

# Gate A/B output (regenerated by run_gate_ab.py replay; ground truth is per-run)
experiments/gate_ab/results.csv

# Scratch: ad-hoc logs + throwaway dump scripts from validation/smoke runs
_*.log
_dump*.py
_*.tmp
